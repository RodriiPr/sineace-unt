# =============================================================
# SINEACE-UNT — Variables de Entorno
# Copia este archivo a .env y completa los valores
# NUNCA subas .env a git (ya está en .gitignore)
# =============================================================

# ----- PostgreSQL / Prisma -----
POSTGRES_USER=sineace_user
POSTGRES_PASSWORD=sineace_pass_2025
POSTGRES_DB=sineace_unt
POSTGRES_PORT=5432

DATABASE_URL="postgresql://sineace_user:sineace_pass_2025@localhost:5432/sineace_unt?schema=public"

# ----- Auth.js v5 (NextAuth) -----
# Genera con: openssl rand -base64 32
AUTH_SECRET=REEMPLAZAR_CON_SECRETO_SEGURO_32_CHARS

# URL base de la app (sin barra al final)
NEXTAUTH_URL=http://localhost:3000

# ----- Opcional: OAuth providers (dejar vacío si no se usa) -----
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ----- Almacenamiento de archivos (desarrollo: local) -----
# Para producción usar S3/R2 y reemplazar esta variable
UPLOAD_DIR=./public/uploads

# ----- App -----
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Sistema de Acreditación SINEACE — UNT"
NEXT_PUBLIC_APP_URL=http://localhost:3000
